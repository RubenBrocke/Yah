{
    "compilerOptions": {
      "target": "ES2018",
      "module": "ESNext",
      "strict": false,
      "noImplicitAny": true,
      "declaration": false,
      "moduleResolution": "Node",
      "isolatedModules": true,
      "esModuleInterop": true,
      "skipLibCheck": true
    },
    "include": ["src", "test"]
  }